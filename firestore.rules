rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId 
                   && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['xp', 'level', 'badges', 'streak']);
    }
    match /predictions/{predId} {
      allow read: if request.auth.uid == resource.data.userId || request.auth.token.admin == true;
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update, delete: if false; 
    }
    match /fantasy_teams/{teamId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow create, update: if request.auth.uid == request.resource.data.userId;
    }
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }
    match /players/{playerId} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }
    match /leaderboard/{doc} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }
  }
}
